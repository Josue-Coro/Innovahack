{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "react",
      "react-native"
    ],
    "allowJs": true
  },
  "include": [
    "./App.js",
    "./src/**/*.js",
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ],
  "extends": "expo/tsconfig.base"
}
