# Database configuration (PostgreSQL via Supabase pooler)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# Environment: "development" enables SQL echo logs, "production" disables them
ENVIRONMENT=production

# Port (Render sets this automatically — do NOT set manually on Render)
# PORT=8000
